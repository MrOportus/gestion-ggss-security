rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si el usuario es Admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/Colaboradores/$(request.auth.uid)).data.role == 'admin';
    }

    // Función auxiliar para verificar si el usuario es Supervisor
    function isSupervisor() {
      return request.auth != null && 
        get(/databases/$(database)/documents/Colaboradores/$(request.auth.uid)).data.role == 'supervisor';
    }
    
    // Función auxiliar para verificar si el usuario es el dueño del documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Reglas para la colección de documentos digitales (Signatures)
    match /documents/{docId} {
      allow create, delete: if isAdmin();
      allow update, read: if isAdmin() || (request.auth != null && resource.data.assignedTo == request.auth.uid);
    }
    
    // Colaboradores (Fichas de empleado)
    match /Colaboradores/{userId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
    }
    
    // Asistencia
    match /Asistencia/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isAdmin() || isSupervisor() || request.resource.data.employeeId == request.auth.uid);
      allow update, delete: if isAdmin() || isSupervisor();
    }
    
    // Rondas (GuardRounds)
    match /Rondas/{roundId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isAdmin() || isSupervisor() || request.resource.data.workerId == request.auth.uid);
      allow update: if request.auth != null && (isAdmin() || isSupervisor() || resource.data.workerId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // SupervisorTasks, ChecklistTemplates, RecurringTasks, etc.
    match /SupervisorTasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isSupervisor();
    }
    
    match /ChecklistTemplates/{templateId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Sucursales, Anticipos, Prestamos, TurnosDiarios, Notas
    match /Sucursales/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /Anticipos/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isSupervisor();
    }

    match /Prestamos/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isSupervisor();
    }

    match /TurnosDiarios/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isSupervisor();
    }

    // Reglas por defecto para cualquier otra colección
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
